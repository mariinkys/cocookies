    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@nuxt/ui": "^4.9.0",
    "@tailwindcss/vite": "^4.3.2",
    "axios": "^1.18.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.2",
    "valibot": "^1.4.2",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.73.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "~1.73.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-vue-devtools": "^8.1.5",
